# Mobile App (Expo)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your_supabase_anon_key

# Database (used by db/ and ingestion/)
# DATABASE_URL=postgresql://postgres:your_password@host:5432/database

# Deputy API (used by ingestion/)
# DEPUTY_BASE_URL=https://your-company.na.deputy.com/api/v1
# DEPUTY_TOKEN=your_deputy_api_token

# Web Dashboard (copy to web/.env.local)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Error Monitoring (optional)
# EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project

# App Store Submission (EAS Submit)
# APPLE_ID=your@apple.id
# ASC_APP_ID=your_app_store_connect_app_id
# APPLE_TEAM_ID=your_apple_team_id

# GitHub Actions secrets needed:
# NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY
# SUPABASE_PROJECT_REF, SUPABASE_ACCESS_TOKEN
# DATABASE_URL, DEPUTY_BASE_URL, DEPUTY_TOKEN
# EXPO_TOKEN
# APPLE_ID, ASC_APP_ID, APPLE_TEAM_ID (for App Store submission)
# SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN
